# Ganti mock ↔ real dengan satu switch (§8)
# false = kiosk terhubung ke Laravel: sortiran, fill, dan status online-nya
# langsung muncul di dashboard admin.
VITE_USE_MOCK=true

# Cloud Laravel (§6)
VITE_API_URL=http://localhost:8000/api

# Sanctum token per-unit ability 'kiosk' — generate di backend: php artisan unit:token {code}
VITE_KIOSK_API_TOKEN=
# unit_code device ini (untuk POST /api/units/{code}/sort-logs, /fill, /heartbeat).
# Harus sama dengan unit pemilik token di atas — kalau beda, backend menolak 403.
VITE_UNIT_CODE=BNB-001

# Jeda relay pembacaan ESP32 → cloud (ms). Layar tetap di-refresh tiap 2 detik;
# ini hanya mengatur seberapa sering snapshot ditulis ke DB. Turunkan saat demo.
VITE_FILL_RELAY_MS=30000

# ESP32 lokal di jaringan yang sama dengan tablet kiosk (§5).
# HOST saja, TANPA /api — prefix itu ditambahkan kiosk sendiri.
# Isi dengan IP yang dicetak firmware di Serial Monitor saat boot — alamatnya
# dibagikan DHCP, jadi bisa berubah setiap kali router/hotspot restart.
VITE_ESP32_BASE_URL=bunnybin.local
# Firmware juga mendaftarkan mDNS: bunnybin.local — hanya bekerja bila
# mesin yang membuka kiosk punya resolver mDNS (avahi/Bonjour) yang hidup.

# Debug Panel — jangan pernah true di build produksi (§9)
VITE_DEBUG_PANEL=true
